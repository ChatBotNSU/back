# ─── Database ───────────────────────────────────────────────────────────────
# Async SQLAlchemy URL. Leave default for local Postgres.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost/chatbot

# ─── Redis (sessions + ARQ + dead-letter queue) ──────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=604800

# ─── Observability ────────────────────────────────────────────────────────────
LOG_FORMAT=text          # text | json
LOG_LEVEL=INFO
SENTRY_DSN=              # set to enable Sentry (requires sentry-sdk installed)
# Prometheus metrics are served at GET /metrics

# ─── API ──────────────────────────────────────────────────────────────────────
# Comma-separated API keys. Each entry is one of:
#   key  |  key:workspace  |  sha256:<hex>  |  sha256:<hex>:workspace
# (hashed entries keep plaintext keys out of the env). Compared in constant time.
# Empty string disables auth (dev mode only); everything maps to "default".
API_KEYS=
DEBUG=false

# Public base URL of this service — required for Telegram setWebhook to fire.
# Leave as the placeholder to skip automatic webhook registration.
BASE_URL=https://yourdomain.com

# Allowed CORS origins (comma-separated). "*" allows all — set real domains in prod.
CORS_ORIGINS=*

# ─── LLM (AI flow generation / improvement) ──────────────────────────────────
# Provider: empty/"openai" → litellm (OPENAI_API_KEY etc.); "yandex" → YandexGPT.
LLM_PROVIDER=
LLM_MODEL=gpt-4o-mini
# OpenAI / litellm: OPENAI_API_KEY=sk-...
# YandexGPT (Yandex Cloud Foundation Models): LLM_PROVIDER=yandex, LLM_MODEL=yandexgpt-lite
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
# Without any LLM configured, flow generation falls back to an offline scaffold.

# ─── Secrets encryption ───────────────────────────────────────────────────────
# Fernet key for encrypting stored integration credentials (CRM/Sheets/payment).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Empty → insecure dev key (logs a warning). MUST be set in production.
SECRETS_KEY=

# ─── Webhook rate limiting (per bot/session key) ──────────────────────────────
WEBHOOK_RATE_LIMIT=30
WEBHOOK_RATE_WINDOW=60
