{
    "server": {
        "host": "0.0.0.0",
        "port": 8080
    },

    "db_service": {
        "host": "db_service",
        "port": 8000
    },

    "authentication": {
        "algorithm": "HS256",
        "access_token_expiration_minutes": 30
    },

    "minio": {
        "host": "minio",
        "port": 9000,
        "access_key": "minioadmin",
        "secret_key": "minioadmin", 
        "bucket_name": "json-bucket"
    },
    
    "redis": {
        "host": "redis",
        "port": 6379,
        "IOStream": {
            "stream_requests": "execution_requests",
            "stream_responses": "execution_responses",
            "group": "execution_group",
            "consumer": "execution_consumer"
        }
    }
}
